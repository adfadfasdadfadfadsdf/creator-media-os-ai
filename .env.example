# ─────────────────────────────────────────────────────────────
# Creator Media OS AI — Environment Variables
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Database (Neon PostgreSQL) — get this from neon.tech → your project → Connection string
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth
JWT_SECRET="replace-this-with-a-long-random-secret-at-least-32-characters"

# AI — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=""
OPENROUTER_DEFAULT_MODEL="meta-llama/llama-3.1-8b-instruct:free"
OPENROUTER_FALLBACK_MODELS="google/gemini-2.0-flash-exp:free,mistralai/mistral-7b-instruct:free"

# YouTube Data API (https://console.cloud.google.com → APIs & Services)
YOUTUBE_API_KEY=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI="http://localhost:3000/api/youtube/oauth/callback"

# Storage (Cloudflare R2 — S3 compatible)
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""

# Encryption key for storing user API keys / OAuth tokens (32 bytes hex)
ENCRYPTION_KEY=""

# Redis (queues / caching) — optional until workers phase
REDIS_URL="redis://localhost:6379"

# Payments (add later)
STRIPE_SECRET_KEY=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
