// Creator Media OS AI — PostgreSQL schema
// Generated for the full SaaS spec. Switch DATABASE_URL to your Neon Postgres URL.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * --------------------------------- Enums ---------------------------------
 */

enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
  CLIENT
}

enum Plan {
  FREE
  CREATOR
  AGENCY
  ENTERPRISE
}

enum AssetType {
  VIDEO
  IMAGE
  AUDIO
  DOC
  LOGO
  INTRO
  OUTRO
  SUBTITLE
  SHORT
  VOICEOVER
  CAPTION
}

enum AssetStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobType {
  VIDEO_UPLOAD
  AUDIO_EXTRACTION
  TRANSCRIPTION
  AI_SUMMARY
  CLIP_DETECTION
  SHORT_RENDER
  CAPTION_GENERATION
  VOICEOVER_GENERATION
  VIDEO_MERGE
  YOUTUBE_UPLOAD
  COMPETITOR_SYNC
  TREND_SYNC
}

enum PublishStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum ApprovalStatus {
  DRAFT
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum SourceType {
  YOUTUBE_URL
  TRANSCRIPT
  MEDIA_ASSET
}

/**
 * --------------------------------- Core ----------------------------------
 */

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatarUrl String?
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  apiKeys         ApiKey[]
  youtubeChannels YoutubeChannel[]
  uploadedAssets  MediaAsset[]      @relation("AssetUploader")
  comments        Comment[]
  usageLogs       UsageLog[]
  trendSearches   TrendSearch[]

  @@index([email])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner           User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members         WorkspaceMember[]
  projects        Project[]
  apiKeys         ApiKey[]
  mediaAssets     MediaAsset[]
  brandKits       BrandKit[]
  youtubeChannels YoutubeChannel[]
  youtubeVideos   YoutubeVideo[]
  trendSearches   TrendSearch[]
  transcripts     Transcript[]
  summaries       VideoSummary[]
  scripts         ShortScript[]
  shorts          Short[]
  voiceovers      Voiceover[]
  captions        Caption[]
  renderJobs      RenderJob[]
  publishJobs     PublishJob[]
  comments        Comment[]
  approvals       Approval[]
  usageLogs       UsageLog[]
  billingPlans    BillingPlan[]
  competitors     Competitor[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(VIEWER)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  niche       String?
  platform    String?
  language    String?  @default("en")
  status      String?  @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mediaAssets   MediaAsset[]
  brandKits     BrandKit[]
  scripts       ShortScript[]
  shorts        Short[]
  renderJobs    RenderJob[]
  publishJobs   PublishJob[]
  comments      Comment[]
  youtubeVideos YoutubeVideo[]

  @@index([workspaceId])
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String?
  workspaceId  String?
  provider     String   @default("openrouter")
  encryptedKey String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
}

/**
 * -------------------------------- Media ----------------------------------
 */

model MediaAsset {
  id          String      @id @default(cuid())
  workspaceId String
  projectId   String?
  uploadedBy  String?
  type        AssetType
  fileName    String
  fileUrl     String?
  storageKey  String?
  mimeType    String?
  size        BigInt?
  duration    Float?
  width       Int?
  height      Int?
  status      AssetStatus @default(UPLOADING)
  tags        String[]    @default([])
  metadata    Json?
  createdAt   DateTime    @default(now())

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploader    User?        @relation("AssetUploader", fields: [uploadedBy], references: [id], onDelete: SetNull)
  transcripts Transcript[]
  shorts      Short[]      @relation("ShortSource")

  @@index([workspaceId])
  @@index([projectId])
  @@index([type])
}

model BrandKit {
  id              String   @id @default(cuid())
  workspaceId     String
  projectId       String?
  name            String
  logoUrl         String?
  watermarkUrl    String?
  primaryColor    String?
  secondaryColor  String?
  font            String?
  captionStyle    String?
  defaultHashtags String[] @default([])
  defaultCta      String?
  introAssetId    String?
  outroAssetId    String?
  voiceTone       String?
  defaultLanguage String?  @default("en")
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

/**
 * -------------------------------- YouTube --------------------------------
 */

model YoutubeChannel {
  id                    String    @id @default(cuid())
  userId                String
  workspaceId           String
  channelId             String
  channelName           String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenExpiry           DateTime?
  createdAt             DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, channelId])
  @@index([userId])
}

model YoutubeVideo {
  id             String    @id @default(cuid())
  workspaceId    String
  projectId      String?
  youtubeVideoId String
  url            String
  title          String?
  description    String?
  channelName    String?
  thumbnailUrl   String?
  views          BigInt?
  likes          BigInt?
  comments       BigInt?
  duration       String?
  publishedAt    DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  summaries VideoSummary[]

  @@index([workspaceId])
}

model TrendSearch {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  country     String?
  language    String?
  category    String?
  resultsJson Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Competitor {
  id          String    @id @default(cuid())
  workspaceId String
  channelId   String
  channelName String?
  lastSyncAt  DateTime?
  insights    Json?
  videosJson  Json?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

/**
 * ------------------------------- AI / Content ----------------------------
 */

model Transcript {
  id           String   @id @default(cuid())
  mediaAssetId String
  workspaceId  String
  language     String?
  rawText      String?
  cleanText    String?
  segmentsJson Json?
  createdAt    DateTime @default(now())

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  captions   Caption[]

  @@index([workspaceId])
  @@index([mediaAssetId])
}

model VideoSummary {
  id               String     @id @default(cuid())
  workspaceId      String
  sourceType       SourceType
  sourceId         String
  youtubeVideoId   String?
  summaryShort     String?
  summaryDetailed  String?
  keyPoints        String[]   @default([])
  viralReason      String?
  targetAudience   String?
  contentAngle     String?
  shortsIdeas      Json?
  titleSuggestions String[]   @default([])
  hashtags         String[]   @default([])
  aiModel          String?
  promptHash       String?
  createdAt        DateTime   @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  youtubeVideo YoutubeVideo? @relation(fields: [youtubeVideoId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([promptHash])
}

model ShortScript {
  id            String   @id @default(cuid())
  workspaceId   String
  projectId     String?
  sourceId      String?
  title         String?
  hook          String?
  script        String?
  voiceoverText String?
  captionsJson  Json?
  onScreenText  String[] @default([])
  hashtags      String[] @default([])
  language      String?  @default("en")
  tone          String?
  duration      Int?
  musicMood     String?
  effects       String[] @default([])
  cta           String?
  createdAt     DateTime @default(now())

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project    Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  shorts     Short[]
  voiceovers Voiceover[]

  @@index([workspaceId])
}

model Short {
  id            String      @id @default(cuid())
  workspaceId   String
  projectId     String?
  sourceAssetId String?
  scriptId      String?
  title         String?
  outputUrl     String?
  thumbnailUrl  String?
  duration      Float?
  aspectRatio   String?     @default("9:16")
  status        AssetStatus @default(PROCESSING)
  renderJobId   String?
  createdAt     DateTime    @default(now())

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sourceAsset MediaAsset?  @relation("ShortSource", fields: [sourceAssetId], references: [id], onDelete: SetNull)
  script      ShortScript? @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  captions    Caption[]
  publishJobs PublishJob[]
  comments    Comment[]
  approvals   Approval[]

  @@index([workspaceId])
  @@index([projectId])
}

model Voiceover {
  id          String   @id @default(cuid())
  workspaceId String
  scriptId    String?
  text        String
  voice       String?
  language    String?
  audioUrl    String?
  duration    Float?
  createdAt   DateTime @default(now())

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  script    ShortScript? @relation(fields: [scriptId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Caption {
  id           String   @id @default(cuid())
  workspaceId  String
  shortId      String?
  transcriptId String?
  style        String?
  srtUrl       String?
  captionsJson Json?
  createdAt    DateTime @default(now())

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  short      Short?      @relation(fields: [shortId], references: [id], onDelete: Cascade)
  transcript Transcript? @relation(fields: [transcriptId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

/**
 * -------------------------------- Jobs -----------------------------------
 */

model RenderJob {
  id           String    @id @default(cuid())
  workspaceId  String
  projectId    String?
  jobType      JobType
  status       JobStatus @default(PENDING)
  inputJson    Json?
  outputJson   Json?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([status])
}

model PublishJob {
  id              String        @id @default(cuid())
  workspaceId     String
  shortId         String?
  platform        String        @default("youtube")
  title           String?
  description     String?
  tags            String[]      @default([])
  scheduledAt     DateTime?
  publishedAt     DateTime?
  status          PublishStatus @default(DRAFT)
  platformVideoId String?
  platformUrl     String?
  errorMessage    String?
  createdAt       DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  short     Short?    @relation(fields: [shortId], references: [id], onDelete: SetNull)
  project   Project?  @relation(fields: [projectId], references: [id])
  projectId String?

  @@index([workspaceId])
  @@index([status])
}

/**
 * ----------------------------- Collaboration -----------------------------
 */

model Comment {
  id               String   @id @default(cuid())
  workspaceId      String
  projectId        String?
  shortId          String?
  userId           String?
  comment          String
  timestampSeconds Float?
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  short     Short?    @relation(fields: [shortId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Approval {
  id          String         @id @default(cuid())
  workspaceId String
  shortId     String?
  clientId    String?
  status      ApprovalStatus @default(DRAFT)
  feedback    String?
  approvedAt  DateTime?
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  short     Short?    @relation(fields: [shortId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

/**
 * -------------------------------- Billing --------------------------------
 */

model UsageLog {
  id           String   @id @default(cuid())
  workspaceId  String
  userId       String?
  action       String
  provider     String?
  model        String?
  inputTokens  Int?     @default(0)
  outputTokens Int?     @default(0)
  creditsUsed  Float?   @default(0)
  metadata     Json?
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([createdAt])
}

model BillingPlan {
  id                 String    @id @default(cuid())
  workspaceId        String
  planName           Plan      @default(FREE)
  status             String    @default("active")
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}
